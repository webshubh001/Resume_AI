{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stored user profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Analysis": {
      "title": "Resume Analysis",
      "description": "An analyzed resume with its extracted data",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "fileName": { "type": "string" },
        "isDefault": { "type": "boolean" },
        "resumeData": { "type": "object" },
        "jobs": { "type": "array" },
        "matches": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "resumeData"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "analyses/{analysisId}": {
      "schema": "Analysis",
      "description": "Collection of analyzed resumes"
    }
  }
}
